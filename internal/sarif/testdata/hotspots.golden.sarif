{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "hc",
          "informationUri": "https://github.com/will-wright-eng/hc",
          "version": "1.2.3",
          "rules": [
            {
              "id": "hot-critical",
              "name": "HotCritical",
              "shortDescription": {
                "text": "Hotspot: high churn × high complexity"
              },
              "fullDescription": {
                "text": "Frequently changed and structurally complex. Highest maintenance risk and the most valuable refactoring target."
              },
              "help": {
                "text": "Reduce complexity (extract, simplify) or stabilize the churn driving changes here. Keep PRs small and add tests before modifying."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "tags": [
                  "maintainability",
                  "hotspot"
                ]
              }
            },
            {
              "id": "hot-simple",
              "name": "HotSimple",
              "shortDescription": {
                "text": "Churny but simple: high churn × low complexity"
              },
              "fullDescription": {
                "text": "Frequently changed but structurally simple — typically configuration or glue code."
              },
              "help": {
                "text": "Low risk. Watch for churn that signals underlying instability."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "tags": [
                  "maintainability",
                  "hotspot"
                ]
              }
            },
            {
              "id": "cold-complex",
              "name": "ColdComplex",
              "shortDescription": {
                "text": "Complex but stable: high complexity × low churn"
              },
              "fullDescription": {
                "text": "Structurally complex but rarely changed — risky to modify when it eventually needs work."
              },
              "help": {
                "text": "Add tests and documentation before modifying. Do not refactor proactively."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "tags": [
                  "maintainability",
                  "hotspot"
                ]
              }
            }
          ]
        }
      },
      "automationDetails": {
        "id": "hc"
      },
      "results": [
        {
          "ruleId": "hot-critical",
          "level": "warning",
          "message": {
            "text": "b.go is a Hot/Critical hotspot (12 commits, weighted 9.1, complexity 250, 3 authors)."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "b.go"
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ],
          "partialFingerprints": {
            "primaryLocationLineHash": "hot-critical:b.go"
          }
        },
        {
          "ruleId": "hot-critical",
          "level": "warning",
          "message": {
            "text": "d.go is a Hot/Critical hotspot (8 commits, weighted 6.5, complexity 180, 2 authors)."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "d.go"
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ],
          "partialFingerprints": {
            "primaryLocationLineHash": "hot-critical:d.go"
          }
        },
        {
          "ruleId": "hot-simple",
          "level": "note",
          "message": {
            "text": "c.go is a Hot/Simple hotspot (3 commits, weighted 2.0, complexity 50, 1 author)."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "c.go"
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ],
          "partialFingerprints": {
            "primaryLocationLineHash": "hot-simple:c.go"
          }
        },
        {
          "ruleId": "cold-complex",
          "level": "note",
          "message": {
            "text": "a.go is a Cold/Complex hotspot (5 commits, weighted 4.2, complexity 120, 2 authors)."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "a.go"
                },
                "region": {
                  "startLine": 1
                }
              }
            }
          ],
          "partialFingerprints": {
            "primaryLocationLineHash": "cold-complex:a.go"
          }
        }
      ]
    }
  ]
}
